# Frontend Environment Variables
# Copy this file to .env.local and fill in your API keys

# ============================================
# CORE CONFIGURATION
# ============================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# ============================================
# AI PROVIDERS (Choose at least one)
# ============================================

# Google Gemini API (FREE - 60 req/min)
# Get key: https://makersuite.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI ChatGPT API (PAID)
# Get key: https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API (PAID)
# Get key: https://console.anthropic.com/
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default AI Provider: 'gemini' | 'chatgpt' | 'claude'
NEXT_PUBLIC_DEFAULT_AI_PROVIDER=gemini

# ============================================
# OPTIONAL: Media & Storage
# ============================================

# Cloudinary (image uploads)
NEXT_PUBLIC_CLOUDINARY_NAME=your_cloudinary_name_here

# ============================================
# OPTIONAL: Monitoring
# ============================================

# Weather API (if using custom weather)
NEXT_PUBLIC_WEATHER_API_KEY=your_weather_api_key_here
